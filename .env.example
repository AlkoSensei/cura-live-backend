APP_ENV=local
CORS_ORIGINS=["*"]

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=kare-appointment-agent
LIVEKIT_MAX_CALL_SECONDS=300

START_EMBEDDED_LIVEKIT_WORKER=true

LIVEKIT_AVATAR_PROVIDER=none
LIVEKIT_AVATAR_PARTICIPANT_IDENTITY=kare-avatar-agent
LIVEKIT_AVATAR_PARTICIPANT_NAME=Kare Avatar
BEY_API_KEY=
BEY_AVATAR_ID=

TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-IN

SARVAM_API_KEY=
SARVAM_LANGUAGE_CODE=en-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_SPEAKER=shubh

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3-flash
POST_CALL_AI_EXTRACTION_ENABLED=true

COST_STT_PER_MINUTE=0.0043
COST_TTS_PER_1K_CHARS=0.03
COST_LLM_INPUT_PER_1M_TOKENS=0.80
COST_LLM_OUTPUT_PER_1M_TOKENS=4.00

COST_FALLBACK_USE_CALL_DURATION=true
COST_FALLBACK_STT_RATIO_OF_CALL_DURATION=1.0
COST_FALLBACK_TTS_CHARS_PER_CALL_SECOND=5.4
