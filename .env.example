APP_ENV=local
CORS_ORIGINS=["*"]

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=kare-appointment-agent
LIVEKIT_MAX_CALL_SECONDS=300

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en-IN

SARVAM_API_KEY=
SARVAM_LANGUAGE_CODE=en-IN
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_SPEAKER=shubh

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

OPENROUTER_API_KEY=
